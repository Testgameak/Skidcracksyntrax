                    OptBtn.MouseButton1Click:Connect(function()
                        SelectedLabel.Text = "Select: " .. opt
                        isDropped = false
                        TweenService:Create(PopupFrame, TweenInfo.new(0.2), {Size = UDim2.new(0, DropBtn.AbsoluteSize.X, 0, 0)}):Play()
                        TweenService:Create(Arrow, TweenInfo.new(0.3), {Rotation = 0}):Play()
                        task.delay(0.2, function() if not isDropped then PopupFrame.Visible = false end end)
                        callback(opt)
                    end)
                end
                ItemContainer.CanvasSize = UDim2.new(0, 0, 0, ItemLayout.AbsoluteContentSize.Y + 5)
            end

            Funcs:Refresh(options)
            return Funcs
        end

        -- ══════════════════════════════════════════════════════════════
        --  ADD SLIDER - Element mới
        -- ══════════════════════════════════════════════════════════════
        function Elements:AddSlider(name, iconId, min, max, default, callback)
            local value = math.clamp(default or min, min, max)
            local draggingSlider = false

            GetParentFrame(false)

            local elemH = isMobile() and 65 or 75
            local SliderFrame = Instance.new("Frame")
            SliderFrame.Size = UDim2.new(1, 0, 0, elemH)
            SliderFrame.BackgroundColor3 = Color3.fromRGB(24, 24, 28)
            SliderFrame.Parent = TabContent
            Instance.new("UICorner", SliderFrame).CornerRadius = UDim.new(0, 8)
            local SliderStroke = Instance.new("UIStroke")
            SliderStroke.Color = Color3.fromRGB(45, 45, 50)
            SliderStroke.Parent = SliderFrame

            local IconBg = nil
            local IconImg = nil
            local textOffsetX = 15
            if iconId and iconId ~= "" then
                IconBg = Instance.new("Frame")
                IconBg.Size = UDim2.new(0, 36, 0, 36)
                IconBg.Position = UDim2.new(0, 15, 0.5, -18)
                IconBg.BackgroundColor3 = Color3.fromRGB(35, 35, 40)
                IconBg.Parent = SliderFrame
                Instance.new("UICorner", IconBg).CornerRadius = UDim.new(0, 8)
                Instance.new("UIStroke", IconBg).Color = Color3.fromRGB(65, 65, 70)
                IconImg = Instance.new("ImageLabel")
                IconImg.Size = UDim2.new(0, 22, 0, 22)
                IconImg.Position = UDim2.new(0.5, -11, 0.5, -11)
                IconImg.BackgroundTransparency = 1
                IconImg.Image = iconId
                IconImg.ImageColor3 = Color3.fromRGB(180, 180, 180)
                IconImg.Parent = IconBg
                textOffsetX = 65
            end

            local TitleLabel = Instance.new("TextLabel")
            TitleLabel.Size = UDim2.new(1, -textOffsetX - 65, 0, 18)
            TitleLabel.Position = UDim2.new(0, textOffsetX, 0, isMobile() and 10 or 12)
            TitleLabel.BackgroundTransparency = 1
            TitleLabel.Text = name
            TitleLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
            TitleLabel.Font = Enum.Font.GothamSemibold
            TitleLabel.TextXAlignment = Enum.TextXAlignment.Left
            TitleLabel.Parent = SliderFrame
            regFont(TitleLabel, 13)

            local ValueLabel = Instance.new("TextLabel")
            ValueLabel.Size = UDim2.new(0, 55, 0, 18)
            ValueLabel.Position = UDim2.new(1, -60, 0, isMobile() and 10 or 12)
            ValueLabel.BackgroundTransparency = 1
            ValueLabel.Text = tostring(value)
            ValueLabel.TextColor3 = Color3.fromRGB(50, 130, 246)
            ValueLabel.Font = Enum.Font.GothamBold
            ValueLabel.TextXAlignment = Enum.TextXAlignment.Right
            ValueLabel.Parent = SliderFrame
            regFont(ValueLabel, 13)

            -- Track nền
            local trackPadRight = 20
            local TrackBg = Instance.new("Frame")
            TrackBg.Size = UDim2.new(1, -(textOffsetX + trackPadRight), 0, 6)
            TrackBg.Position = UDim2.new(0, textOffsetX, 0, isMobile() and 44 or 50)
            TrackBg.BackgroundColor3 = Color3.fromRGB(40, 40, 45)
            TrackBg.Parent = SliderFrame
            Instance.new("UICorner", TrackBg).CornerRadius = UDim.new(1, 0)

            -- Track fill
            local fillRatio = (value - min) / math.max(max - min, 1)
            local TrackFill = Instance.new("Frame")
            TrackFill.Size = UDim2.new(fillRatio, 0, 1, 0)
            TrackFill.BackgroundColor3 = Color3.fromRGB(50, 130, 246)
            TrackFill.Parent = TrackBg
            Instance.new("UICorner", TrackFill).CornerRadius = UDim.new(1, 0)

            -- Thumb
            local Thumb = Instance.new("Frame")
            Thumb.Size = UDim2.new(0, 14, 0, 14)
            Thumb.Position = UDim2.new(fillRatio, -7, 0.5, -7)
            Thumb.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
            Thumb.ZIndex = 5
            Thumb.Parent = TrackBg
            Instance.new("UICorner", Thumb).CornerRadius = UDim.new(1, 0)
            local ThumbStroke = Instance.new("UIStroke")
            ThumbStroke.Color = Color3.fromRGB(50, 130, 246)
            ThumbStroke.Thickness = 2
            ThumbStroke.Parent = Thumb

            local function updateSlider(inputX)
                local trackAbs = TrackBg.AbsolutePosition.X
                local trackWidth = TrackBg.AbsoluteSize.X
                local ratio = math.clamp((inputX - trackAbs) / trackWidth, 0, 1)
                value = math.floor(min + (max - min) * ratio)
                local fr = (value - min) / math.max(max - min, 1)
                TweenService:Create(TrackFill, TweenInfo.new(0.05), {Size = UDim2.new(fr, 0, 1, 0)}):Play()
                TweenService:Create(Thumb,     TweenInfo.new(0.05), {Position = UDim2.new(fr, -7, 0.5, -7)}):Play()
                ValueLabel.Text = tostring(value)
                callback(value)
            end

            TrackBg.InputBegan:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1
                or input.UserInputType == Enum.UserInputType.Touch then
                    draggingSlider = true
                    updateSlider(input.Position.X)
                end
            end)

            -- Cho phép bắt đầu drag từ Thumb luôn
            Thumb.InputBegan:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1
                or input.UserInputType == Enum.UserInputType.Touch then
                    draggingSlider = true
                end
            end)

            UserInputService.InputChanged:Connect(function(input)
                if draggingSlider and (
                    input.UserInputType == Enum.UserInputType.MouseMovement
                    or input.UserInputType == Enum.UserInputType.Touch
                ) then
                    updateSlider(input.Position.X)
                end
            end)

            UserInputService.InputEnded:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1
                or input.UserInputType == Enum.UserInputType.Touch then
                    draggingSlider = false
                end
            end)

            -- Hover effect
            SliderFrame.MouseEnter:Connect(function()
                TweenService:Create(SliderStroke, TweenInfo.new(0.2), {Color = Color3.fromRGB(65, 65, 75)}):Play()
                TweenService:Create(TrackFill,    TweenInfo.new(0.2), {BackgroundColor3 = Color3.fromRGB(80, 160, 255)}):Play()
                if IconBg  then TweenService:Create(IconBg,  TweenInfo.new(0.2), {BackgroundColor3 = Color3.fromRGB(28, 50, 90)}):Play() end
                if IconImg then TweenService:Create(IconImg, TweenInfo.new(0.2), {ImageColor3 = Color3.fromRGB(255, 255, 255)}):Play() end
            end)
            SliderFrame.MouseLeave:Connect(function()
                TweenService:Create(SliderStroke, TweenInfo.new(0.2), {Color = Color3.fromRGB(45, 45, 50)}):Play()
                TweenService:Create(TrackFill,    TweenInfo.new(0.2), {BackgroundColor3 = Color3.fromRGB(50, 130, 246)}):Play()
                if IconBg  then TweenService:Create(IconBg,  TweenInfo.new(0.2), {BackgroundColor3 = Color3.fromRGB(35, 35, 40)}):Play() end
                if IconImg then TweenService:Create(IconImg, TweenInfo.new(0.2), {ImageColor3 = Color3.fromRGB(180, 180, 180)}):Play() end
            end)

            -- Trả về object để set value từ ngoài nếu cần
            local SliderFuncs = {}
            function SliderFuncs:SetValue(v)
                value = math.clamp(v, min, max)
                local fr = (value - min) / math.max(max - min, 1)
                TrackFill.Size = UDim2.new(fr, 0, 1, 0)
                Thumb.Position = UDim2.new(fr, -7, 0.5, -7)
                ValueLabel.Text = tostring(value)
            end
            return SliderFuncs
        end

        return Elements
    end
    return Window
end

return MoonLightHub

